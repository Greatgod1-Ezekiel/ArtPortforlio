<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ezekiel Pencil Art | Gallery & Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-main: #ffffff;
            --text-dim: #b3b3b3;
            --accent: #d4af37;
            --font-heading: 'Playfair Display', serif;
            --font-body: 'Inter', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-body);
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 60px 20px;
        }

        /* TOP NAVBAR BRANDING */
        .nav-brand {
            position: absolute;
            top: 20px;
            left: 20px;
            font-weight: 600;
            letter-spacing: 2px;
            font-size: 12px;
            color: var(--text-main);
            z-index: 10;
        }

        .small-tag {
            color: var(--accent);
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            display: block;
            margin-bottom: 12px;
            font-size: 0.75rem;
        }

        .section-title {
            font-family: var(--font-heading);
            font-size: 2.2rem;
            margin-bottom: 40px;
            line-height: 1.2;
        }

        .btn {
            padding: 14px 30px;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
        }

        .btn.primary { background: var(--text-main); color: #000; }

        /* GALLERY HEADER (LEFT ALIGNED) */
        .gallery-header {
            text-align: left;
            padding: 160px 20px 80px;
            background: linear-gradient(to right, rgba(0,0,0,0.9), rgba(0,0,0,0.4)), url('ba.jpg');
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .main-heading {
            font-family: var(--font-heading);
            font-size: clamp(2.5rem, 6vw, 4rem);
            margin-bottom: 20px;
            max-width: 800px;
        }

        .header-para {
            max-width: 600px;
            color: var(--text-dim);
            font-size: 1.1rem;
        }

        /* ABOUT ME SECTION (LEFT ALIGNED) */
        .about-me {
            background: #161616;
            padding: 100px 0;
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .about-me-img {
            width: 100%;
            height: 500px;
            background: #252525;
            border-radius: 15px;
            overflow: hidden;
        }

        .about-me-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .about-content {
            text-align: left;
        }

        .about-content p {
            margin-bottom: 25px;
            color: var(--text-dim);
            font-size: 12px;
            
            line-height: 1.9;
        }

        /* CLIENT PHOTOS GRID */
        .photo-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 25px;
            margin-top: 50px;
        }

        .photo-item {
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
            transition: 0.4s;
            
        }

        .photo-item:hover { transform: translateY(-10px); }

        .photo-item img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            border-radius: 350px;
        }

@media (max-width: 768px) {
    .photo-item img {
            width: 50%;
            height: 200px;
            object-fit: cover;
            margin-left: 90px;
            margin-top: 30px;
            border-radius: 350px;
        }
}



        .photo-item span {
            display: block;
            padding: 15px;
            text-align: center;
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--accent);
            text-transform: uppercase;
        }

        /* SERVICES SECTION (WHITE BG) */
        .services-white {
            background: #ffffff;
            color: #000000;
            padding: 100px 0;
        }

        .services-white .section-title {
            color: #000000;
            text-align: center;
            margin-bottom: 60px;
        }

        .services-flex {
            max-width: 700px;
            margin: 0 auto;
        }

        .service-row {
            display: flex;
            align-items: flex-start;
            gap: 30px;
            margin-bottom: 50px;
        }

        .service-icon {
            flex-shrink: 0;
            width: 70px;
        }

        .service-icon i {
            font-size: 3rem;
            color: #333;
        }

        .service-text h3 {
            font-family: var(--font-body);
            font-size: 1.5rem;
            margin-bottom: 10px;
            font-weight: 400;
            color: #444;
        }

        .service-text p {
            color: #666;
            font-size: 1rem;
            line-height: 1.6;
        }

        footer {
    background: #0a0a0a;
    padding: 25px 0; /* reduced from 60px */
    text-align: center;
    border-top: 1px solid #222;
}

.copyright {
    color: #f5f5f5; /* brighter white */
    font-size: 0.8rem;
}

        @media (max-width: 992px) {
            .about-grid { grid-template-columns: 1fr; }
            .about-me-img { height: 350px; order: 2; }
            .about-content { order: 1; }
        }

        @media (max-width: 768px) {
            .service-row { flex-direction: column; text-align: center; align-items: center; }
            .section-title { font-size: 1.8rem; }
        }
        
        .drawing-stages {
    background: #161616;
    padding: 100px 0;
}

.stages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 30px;
    margin-top: 40px;
}

.stage-card {
    background: #1e1e1e;
    padding: 20px;
    border-radius: 15px;
    text-align: center;
    transition: all 0.35s ease;
    position: relative;
}

/* Soft faded glow on hover / touch */
.stage-card:hover,
.stage-card:active {
    transform: translateY(-8px);
    box-shadow: 0 0 35px rgba(212, 175, 55, 0.25);
}
.stage-card:hover,
.stage-card:active {
    transform: translateY(-8px);
    box-shadow: 0 0 25px rgba(212, 175, 55, 0.6),
                0 0 60px rgba(212, 175, 55, 0.4);
}




.stage-card img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 15px;
}

.stage-card h3 {
    color: var(--accent);
    margin-bottom: 10px;
    font-size: 1.2rem;
}

.stage-card p {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.6;
}
    
.materials {
    position: relative;
    padding: 100px 0;
    background: url(1313.png) center/cover no-repeat;
    z-index: 1;
}

/* dark overlay layer */
.materials::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
        rgba(0, 0, 0, 0.75),
        rgba(0, 0, 0, 0.75)
    );
    z-index: -1;
}

.materials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-top: 40px;
}

@media (max-width: 992px) {
    .materials-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 600px) {
    .materials-grid {
        grid-template-columns: 1fr;
    }
}



.material-card {
    background: #1e1e1e;
    padding: 25px;
    border-radius: 15px;
    transition: 0.3s ease;
    box-shadow: 0 0 0 rgba(0,0,0,0);
}



.material-card h3 {
    color: var(--accent);
    margin-bottom: 15px;
    font-size: 1.2rem;
}

.material-card p {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.7;
}    
.timeline {
    background: #1a1a1a;
    padding: 100px 0;
}

.timeline-box {
    max-width: 800px;
    margin: 40px auto 0;
    border-left: 2px solid var(--accent);
    padding-left: 35px;
}

/* Each item has strong separation */
.timeline-item {
    position: relative;
    margin-bottom: 80px; /* 👈 BIG SPACE BETWEEN ITEMS */
}

/* Accent dot */
.timeline-item::before {
    content: "";
    position: absolute;
    left: -43px;
    top: 6px;
    width: 12px;
    height: 12px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.4);
}

/* YEAR HEADING */
.timeline-item h3 {
    color: var(--accent);
    font-size: 1.25rem;
    margin-bottom: 15px;
    letter-spacing: 0.5px;
}

/* DESCRIPTION */
.timeline-item p {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.8;
    max-width: 650px;
}
    .gallery-slider {
    background: #ffffff;
    color: #000;
    padding: 100px 0;
}

.gallery-slider .section-title {
    text-align: center;
    color: #000;
}

.slider-box {
    position: relative;
    max-width: 700px;
    margin: 50px auto 0;
    overflow: hidden;
}

.slider-wrapper {
    display: flex;
    transition: transform 0.5s ease-in-out;
}

.slide {
    min-width: 100%;
    text-align: center;
}

.slide img {
    width: 100%;
    height: 470px;
    object-fit: cover;
    border-radius: 15px;
}

.slide p {
    margin-top: 10px;
    font-weight: 600;
    color: #444;
}

/* ARROWS */
.nav {
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    background: #000;
    color: #fff;
    border: none;
    padding: 12px 15px;
    cursor: pointer;
    border-radius: 50%;
    z-index: 10;
}

.nav.left { left: 10px; }
.nav.right { right: 10px; }

.nav:hover {
    background: var(--accent);
    color: #000;
}
   /* ===== Scroll Reveal Animation ===== */
.reveal {
    opacity: 0;
    transform: translateY(60px);
    transition: all 0.9s ease;
}

.reveal.show {
    opacity: 1;
    transform: translateY(0);
}    
   
   /* ===== GLOBAL LARGE SCREEN CONTROL ===== */
@media (min-width: 1200px) {

    .container {
        max-width: 1200px;
        padding: 80px 40px;
    }

    /* Keep all text content centered but not stretched */
    p {
        max-width: 800px;
    }

    /* ===== HEADER ===== */
    .gallery-header {
        padding: 200px 0 120px;
    }

    .gallery-header .container {
        max-width: 1100px;
    }

    /* ===== ABOUT SECTION ===== */
    .about-grid {
        gap: 80px;
    }

    .about-content p {
        font-size: 0.95rem;
    }

    /* ===== PHOTO GRID ===== */
    .photo-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 30px;
    }

    .photo-item img {
        height: 320px;
    }

    /* ===== SERVICES ===== */
    .services-flex {
        max-width: 900px;
    }

    .service-text h3 {
        font-size: 1.6rem;
    }

    /* ===== DRAWING STAGES ===== */
    .stages-grid {
        grid-template-columns: repeat(4, 1fr);
    }

    /* ===== MATERIALS ===== */
    .materials-grid {
        grid-template-columns: repeat(3, 1fr);
        max-width: 1100px;
        margin: 40px auto 0;
    }

    /* ===== TIMELINE ===== */
    .timeline-box {
        max-width: 900px;
    }

    /* ===== SLIDER ===== */
    .slider-box {
        max-width: 850px;
    }

    .slide img {
        height: 500px;
    }

    /* ===== CENTER ALIGN MAIN SECTIONS CLEANLY ===== */
    .section-title {
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .small-tag {
        display: block;
        text-align: center;
    }
}
   
   /* ===== PRICING SECTION ===== */
.pricing-section {
    background: #000;
    padding: 100px 0;
    text-align: center;
}

.pricing-card {
    background: #111;
    max-width: 750px;
    margin: 50px auto 0;
    padding: 50px 35px;
    border-radius: 20px;
    border: 1px solid #222;
    transition: 0.4s ease;
}

.pricing-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 0 35px rgba(212, 175, 55, 0.2);
}

.price-top h3 {
    color: var(--text-dim);
    font-size: 1rem;
    margin-bottom: 15px;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.price-top h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    color: var(--accent);
    margin-bottom: 20px;
    font-family: var(--font-heading);
}

.price-top h1 span {
    font-size: 2rem;
}

.price-text {
    color: var(--text-dim);
    line-height: 1.9;
    margin-bottom: 20px;
    font-size: 0.95rem;
}

.price-features {
    margin-top: 35px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
}

.feature {
    background: #1a1a1a;
    padding: 18px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: center;
}

.feature i {
    color: var(--accent);
    font-size: 1rem;
}

.feature span {
    color: #ddd;
    font-size: 0.9rem;
}
    
   /* ===============================
   SERVICES SECTION - LARGE SCREENS
================================== */
@media (min-width: 992px) {

    .services-flex {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 40px;
    }

    .service-row {
        background: #f7f7f7;
        padding: 30px;
        border-radius: 18px;
        margin-bottom: 0;
        align-items: flex-start;
    }

    .service-text h3 {
        font-size: 1.4rem;
    }

    .service-text p {
        font-size: 0.95rem;
    }
}


/* ==========================================
   MATERIALS SECTION - LARGE SCREEN LAYOUT
========================================== */
@media (min-width: 1200px) {

    .materials-grid {
        display: flex;
        flex-direction: column;
        gap: 35px;
        max-width: 1100px;
