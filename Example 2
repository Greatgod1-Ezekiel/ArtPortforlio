    }
}


/* ==========================================
   GALLERY IMAGE FIX FOR LARGE SCREENS
========================================== */
@media (min-width: 1200px) {

    .slider-box {
        max-width: 1000px;
    }

    .slide img {
        width: 100%;
        height: auto;
        max-height: 700px;
        object-fit: contain;
        background: #fff;
        border-radius: 15px;
    }
} 
    
  /* ==========================================
   FIX ABOUT IMAGE ON MOBILE
========================================== */
@media (max-width: 768px) {

    .about-me-img {
        height: auto;
