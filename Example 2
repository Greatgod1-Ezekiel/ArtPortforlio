/* ==========================================
   FIX GALLERY IMAGES ON MOBILE
========================================== */
@media (max-width: 768px) {

    .slider-box {
        width: 100%;
        max-width: 100%;
    }

    .slide {
        padding: 0 10px;
    }

    .slide img {
        width: 100%;
        height: auto;
        max-height: 500px;
