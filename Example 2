}  
    
    /* ==========================================
TESTIMONIALS SECTION
========================================== */
.testimonials {
    position: relative;
    background-image: url('PRO.png');
    background-size: cover;
    background-position: center;
    padding: 100px 0;
    text-align: center;
    z-index: 1;
}

/* DARK OVERLAY */
.testimonials::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75); /* adjust darkness here */
    z-index: -1;
}

.testimonial-slider {
    max-width: 750px;
    margin: 50px auto 0;
    overflow: hidden;
    position: relative;
}

.testimonial-wrapper {
    display: flex;
    transition: transform 0.5s ease;
}

.testimonial-slide {
    min-width: 100%;
    padding: 20px;
}

.testimonial-slide img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    border-radius: 50%;
    margin-bottom: 25px;
    border: 4px solid var(--accent);
}

.review-text {
    color: var(--text-dim);
    font-size: 1rem;
    line-height: 1.9;
    margin-bottom: 20px;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
}

.testimonial-slide h3 {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 600;
}

/* DOTS */
.testimonial-dots {
    margin-top: 30px;
    display: flex;
    justify-content: center;
    gap: 12px;
}

.dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #444;
    cursor: pointer;
    transition: 0.3s ease;
}

.dot.active {
    background: var(--accent);
    transform: scale(1.2);
}

/* MOBILE */
@media (max-width: 768px) {

    .testimonial-slide img {
        width: 90px;
        height: 90px;
    }

    .review-text {
        font-size: 0.92rem;
    }
}
   .guide-section {
    background: #ffffff;
    color: #000;
    padding: 100px 0;
}

.guide-section .section-title {
    color: #000;
    text-align: center;
}

.guide-wrapper {
    max-width: 800px;
    margin: 50px auto 0;
}

.guide-item {
    border-bottom: 1px solid #ddd;
    padding: 20px 0;
}

.guide-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
}

.guide-header h3 {
    font-size: 1.1rem;
    font-weight: 600;
}

.icon {
    font-size: 1.5rem;
    font-weight: bold;
    transition: 0.3s;
}

.guide-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    padding-right: 20px;
}

.guide-content p {
    color: #555;
    line-height: 1.8;
    margin-top: 15px;
    font-size: 0.95rem;
} 
  
  .commission-section {
    background: #0f0f0f;
    color: #fff;
    padding: 100px 0;
    text-align: center;
}

.commission-note {
    max-width: 600px;
    margin: 0 auto 40px;
    color: #aaa;
    line-height: 1.8;
    font-size: 0.95rem;
}

.commission-form {
    max-width: 800px;
    margin: 0 auto;
    background: #1a1a1a;
    padding: 40px;
    border-radius: 15px;
    text-align: left;
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.input-box {
    display: flex;
    flex-direction: column;
}

.input-box.full {
    grid-column: span 2;
}

.input-box label {
    margin-bottom: 8px;
    font-size: 0.85rem;
    color: #ccc;
}

.input-box input,
.input-box select,
.input-box textarea {
    padding: 12px;
    border: 1px solid #333;
    background: #111;
    color: #fff;
    border-radius: 8px;
    outline: none;
    font-size: 0.9rem;
}

.input-box input:focus,
.input-box select:focus,
.input-box textarea:focus {
    border-color: var(--accent);
}

.commission-btn {
    margin-top: 25px;
    width: 100%;
    background: var(--accent);
    color: #000;
    font-weight: 700;
}

.commission-btn:hover {
    opacity: 0.9;
}
 /* ===== MOBILE FIX FOR COMMISSION FORM ===== */
@media (max-width: 768px) {

    .commission-form {
        padding: 25px 15px;
    }

    .form-grid {
        grid-template-columns: 1fr; /* stack into one column */
    }

    .input-box.full {
        grid-column: span 1; /* prevent forced 2-column span */
    }

    .input-box input,
    .input-box select,
    .input-box textarea {
        font-size: 0.9rem;
        width: 100%;
    }

    .commission-btn {
        width: 100%;
    }
} 
